#!/usr/bin/env python3

import os
import platform
import shutil
import subprocess
import sys

EnsureSConsVersion(4, 0)


def detect_platform():
    if sys.platform.startswith("win32"):
        return "windows"
    if sys.platform.startswith("darwin"):
        return "macos"
    if sys.platform.startswith("linux"):
        return "linux"
    raise ValueError("Unsupported platform: {}".format(sys.platform))


def build_static_archive(target, source, env):
    target_path = str(target[0])
    source_paths = [str(node) for node in source]
    if os.path.exists(target_path):
        os.remove(target_path)

    chunk_size = 64
    for index in range(0, len(source_paths), chunk_size):
        chunk = source_paths[index:index + chunk_size]
        subprocess.check_call([env["AR"], "rcs", target_path] + chunk)


def copy_runtime_file(target, source, env):
    source_path = str(source[0])
    target_path = str(target[0])
    target_dir = os.path.dirname(target_path)

    if target_dir and not os.path.exists(target_dir):
        os.makedirs(target_dir)

    shutil.copy2(source_path, target_path)


opts = Variables([], ARGUMENTS)
opts.Add(EnumVariable("platform", "Target platform", detect_platform(), ["windows", "linux", "macos"]))
opts.Add(EnumVariable("target", "Build target", "debug", ["debug", "release"]))
opts.Add(EnumVariable("arch", "Target architecture", "x86_64", ["x86_64", "x86_32", "arm64", "arm32"]))
opts.Add(BoolVariable("asan", "Build SDL shell with AddressSanitizer", False))
opts.Add(BoolVariable("experimental_audio", "Build with transformed m4a runtime enabled", False))
opts.Add(PathVariable("sdl_include_dir", "Path to SDL3 headers", os.environ.get("SDL3_INCLUDE_DIR", "C:/SDL3/x86_64-w64-mingw32/include"), PathVariable.PathAccept))
opts.Add(PathVariable("sdl_lib_dir", "Path to SDL3 libraries", os.environ.get("SDL3_LIB_DIR", "C:/SDL3/x86_64-w64-mingw32/lib"), PathVariable.PathAccept))
opts.Add(PathVariable("sdl_bin_dir", "Path to SDL3 runtime DLLs", os.environ.get("SDL3_BIN_DIR", "C:/SDL3/x86_64-w64-mingw32/bin"), PathVariable.PathAccept))

if ARGUMENTS.get("platform", detect_platform()) == "windows":
    env = Environment(tools=["mingw", "gcc", "ar"], variables=opts)
else:
    env = Environment(tools=["default"], variables=opts)

Help(opts.GenerateHelpText(env))

project_dir = Dir(".").abspath
root_dir = Dir("../../..").abspath
_tools_dir = os.path.join(root_dir, "tools")
if _tools_dir not in sys.path:
    sys.path.insert(0, _tools_dir)
import portable_scons_helpers as _psh

_pc = _psh.portable_repo_paths(root_dir)
_psh.run_portable_generators(root_dir, _pc["generated_dir"])
core_dir = _pc["core_dir"]
core_include_dir = _pc["core_include_dir"]
core_src_dir = _pc["core_src_dir"]
engine_root_dir = _pc["engine_root_dir"]
engine_core_dir = _pc["engine_core_dir"]
engine_interfaces_dir = _pc["engine_interfaces_dir"]
firered_core_module_dir = _pc["firered_core_module_dir"]
firered_portable_dir = _pc["firered_portable_dir"]
firered_generated_data_dir = _pc["firered_generated_data_dir"]
generated_dir = _pc["generated_dir"]
generated_include_dir = _pc["generated_include_dir"]
generated_src_dir = _pc["generated_src_dir"]
engine_src_dir = _pc["engine_src_dir"]
engine_transformed_dir = _pc["engine_transformed_dir"]
engine_include_dir = _pc["engine_include_dir"]
engine_gba_include_dir = _pc["engine_gba_include_dir"]
build_dir = os.path.join(root_dir, "build")
sdl_build_dir = os.path.join(build_dir, "sdl")
sdl_object_dir = os.path.join(sdl_build_dir, "obj")


def object_target_for(source_path):
    rel_path = os.path.relpath(source_path, root_dir)
    base, _ = os.path.splitext(rel_path)
    return os.path.join(sdl_object_dir, base + ".o")


def build_objects(builder_env, sources):
    objects = []

    for source_path in sources:
        objects.extend(builder_env.Object(target=object_target_for(source_path), source=source_path))

    return objects


engine_sources = _psh.merged_engine_c_sources(env["experimental_audio"], _pc)
portable_asm_sources = _psh.portable_asm_c_sources(_pc)
core_sources = _psh.core_c_sources(_pc)
release_sensitive_prefixes = _psh.portable_release_sensitive_prefixes(root_dir)

c_env = env.Clone()
c_env["CC"] = "gcc"
c_env.Append(CPPPATH=[project_dir, generated_include_dir, generated_src_dir, engine_include_dir, engine_gba_include_dir, engine_src_dir, core_include_dir, core_src_dir, engine_core_dir, engine_interfaces_dir, firered_core_module_dir])
c_env.Append(CCFLAGS=[
    "-std=gnu99",
    "-Wall",
    "-Wextra",
    "-Wno-unused-parameter",
    "-Wno-unused-variable",
    "-Wno-unused-function",
    "-Wno-missing-field-initializers",
    "-Wno-sign-compare",
    "-Wno-pointer-sign",
    "-Wno-int-conversion",
    "-Wno-implicit-function-declaration",
    "-Wno-strict-aliasing",
    "-Wno-type-limits",
    "-Wno-implicit-fallthrough",
    "-Wno-unused-but-set-variable",
    "-Wno-unused-value",
    "-Wno-int-to-pointer-cast",
    "-Wno-pointer-to-int-cast",
    "-Wno-unknown-escape-sequence",
    "-Wno-overflow",
    "-Wno-builtin-declaration-mismatch",
    "-Wno-discarded-qualifiers",
    "-Wno-unterminated-string-initialization",
    "-Wno-missing-braces",
    "-Wno-attribute-alias",
    "-Wno-empty-body",
    "-fPIC",
    "-Wa,-I,{}".format(root_dir.replace("\\", "/")),
])

# The merged portable tree still carries a large volume of legacy decomp and
# generated-code warnings. Keep the SDL shell build output actionable while
# we continue chipping away at the underlying backlog in code.
c_env.Append(CCFLAGS=["-w"])
if env["sdl_include_dir"]:
    c_env.Append(CPPPATH=[env["sdl_include_dir"]])
c_env.Append(CPPDEFINES=["PORTABLE", "NO_SAVEFLASH", "FIRERED", "GAME_LANGUAGE=2", "PORTABLE_FAKE_INCBIN", "__INTELLISENSE__"])
if env["experimental_audio"]:
    c_env.Append(CPPDEFINES=["FIRERED_EXPERIMENTAL_AUDIO"])

if env["platform"] == "windows":
    c_env.Append(CCFLAGS=["-mms-bitfields", "-m64" if env["arch"] == "x86_64" else "-m32"])
    c_env.Append(CPPDEFINES=["WIN32", "_WINDOWS"])

if env["target"] == "debug":
    c_env.Append(CCFLAGS=["-g3", "-O0", "-DDEBUG", "-D_DEBUG", "-fno-omit-frame-pointer"])
else:
    c_env.Append(CCFLAGS=["-O2", "-DNDEBUG", "-fomit-frame-pointer"])

if env["asan"]:
    c_env.Append(CCFLAGS=["-fsanitize=address", "-fno-omit-frame-pointer", "-g"])
    c_env.Append(LINKFLAGS=["-fsanitize=address"])

if not os.path.exists(build_dir):
    os.makedirs(build_dir)
if not os.path.exists(sdl_build_dir):
    os.makedirs(sdl_build_dir)

release_safe_env = c_env.Clone()
if env["target"] == "release":
    release_safe_env.Append(CCFLAGS=["-O0", "-fno-omit-frame-pointer"])

normal_sources = []
stability_sources = []
for source_path in engine_sources + core_sources:
    normalized = os.path.normcase(source_path)
    if env["target"] == "release" and any(normalized.startswith(prefix) for prefix in release_sensitive_prefixes):
        stability_sources.append(source_path)
    else:
        normal_sources.append(source_path)

core_objects = build_objects(c_env, normal_sources)
core_objects += build_objects(release_safe_env, stability_sources)
asm_c_env = c_env.Clone()
asm_c_env.Append(CCFLAGS=["-fno-asm"])
core_objects += build_objects(asm_c_env, portable_asm_sources)
# main_portable.c #includes src_transformed/main.c; track it so main.c edits rebuild.
Depends(
    object_target_for(os.path.join(firered_portable_dir, "main_portable.c")),
    os.path.join(root_dir, "src_transformed", "main.c"),
)
firered_core_lib = c_env.Command(
    target=os.path.join(sdl_build_dir, "libfirered_core_sdl.a"),
    source=core_objects,
    action=build_static_archive,
)

runner_env = c_env.Clone()
runner_libs = []
if env["platform"] == "windows":
    runner_libs = ["winmm", "ws2_32", "crypt32"]
runner_program = runner_env.Program(
    target=os.path.join(build_dir, "runtime_progress_runner"),
    source=[os.path.join(root_dir, "tools", "runtime_progress_runner.c"), firered_core_lib],
    LIBPATH=[env["sdl_lib_dir"]] if env["sdl_lib_dir"] else [],
    LIBS=runner_libs,
)
runner_env.Depends(runner_program, firered_core_lib)
Default(runner_program)

shell_program = os.path.join(build_dir, "decomp_engine_sdl")
libs = ["SDL3"]
if env["platform"] == "windows":
    libs = ["mingw32", "SDL3", "winmm", "ws2_32", "crypt32"]

program = c_env.Program(
    target=shell_program,
    source=build_objects(c_env, [os.path.join(project_dir, "main.c")]) + [firered_core_lib],
    LIBPATH=[env["sdl_lib_dir"]] if env["sdl_lib_dir"] else [],
    LIBS=libs,
)

Default(program)

# ── Launcher ────────────────────────────────────────────────────────────
launcher_dir = os.path.join(project_dir, "launcher")
launcher_program = os.path.join(build_dir, "nativecart_launcher")
launcher_env = c_env.Clone()
# Launcher only needs SDL3, no game libraries
launcher_env.Append(CPPPATH=[launcher_dir])

launcher_libs = ["SDL3"]
if env["platform"] == "windows":
    launcher_libs = ["mingw32", "SDL3", "winmm", "ws2_32", "crypt32"]

launcher = launcher_env.Program(
    target=launcher_program,
    source=build_objects(launcher_env, [os.path.join(launcher_dir, "launcher.c")]),
    LIBPATH=[env["sdl_lib_dir"]] if env["sdl_lib_dir"] else [],
    LIBS=launcher_libs,
)
Alias("launcher", launcher)

if env["platform"] == "windows" and env["sdl_bin_dir"]:
    runtime_dll = c_env.Command(
        target=os.path.join(build_dir, "SDL3.dll"),
        source=os.path.join(env["sdl_bin_dir"], "SDL3.dll"),
        action=copy_runtime_file,
    )
    Depends(runtime_dll, program)
    Default(runtime_dll)

print("SDL shell build root: {}".format(root_dir))

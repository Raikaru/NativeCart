; =============================================================================
; Example Godot Scene: PokeFireRed Player
; =============================================================================
; This is an example .tscn file demonstrating how to use the PokeFireRed
; GDExtension in your Godot project.
; 
; Copy this content into a scene file (e.g., main.tscn) and place the
; mod_manager.gd script in your project.
; =============================================================================

[gd_scene load_steps=3 format=3 uid="uid://example_scene"]

[ext_resource type="Script" path="res://addons/pokefirered/scripts/mod_manager.gd" id="1_modmgr"]
[ext_resource type="Script" path="res://example_player.gd" id="2_player"]

[node name="PokeFireRedMain" type="Node"]

[node name="PokeFireRedModManager" type="Node" parent="."]
unique_name_in_owner = true
script = ExtResource("1_modmgr")
auto_load_rom_on_start = false
rom_file_path = ""
patches_folder = "user://patches/"
save_folder = "user://saves/"

[node name="UI" type="CanvasLayer" parent="."]

[node name="MainMenu" type="Control" parent="UI"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="UI/MainMenu"]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = -100.0
offset_right = 150.0
offset_bottom = 100.0
grow_horizontal = 2
grow_vertical = 2

[node name="Title" type="Label" parent="UI/MainMenu/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "PokeFireRed GDExtension"
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="UI/MainMenu/VBoxContainer"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2

[node name="LoadRomButton" type="Button" parent="UI/MainMenu/VBoxContainer"]
layout_mode = 2
text = "Load ROM"

[node name="ApplyPatchesButton" type="Button" parent="UI/MainMenu/VBoxContainer"]
layout_mode = 2
text = "Apply Patches"

[node name="StartButton" type="Button" parent="UI/MainMenu/VBoxContainer"]
layout_mode = 2
text = "Start Emulation"

[node name="SaveButton" type="Button" parent="UI/MainMenu/VBoxContainer"]
layout_mode = 2
text = "Save Game"

[node name="LoadSaveButton" type="Button" parent="UI/MainMenu/VBoxContainer"]
layout_mode = 2
text = "Load Save"

[node name="StatusLabel" type="Label" parent="UI/MainMenu/VBoxContainer"]
layout_mode = 2
text = "Status: Ready"
horizontal_alignment = 1

[node name="GameDisplay" type="TextureRect" parent="UI"]
unique_name_in_owner = true
visible = false
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -120.0
offset_top = -80.0
offset_right = 120.0
offset_bottom = 80.0
grow_horizontal = 2
grow_vertical = 2
stretch_mode = 5

[node name="ExamplePlayer" type="Node" parent="."]
script = ExtResource("2_player")

[connection signal="pressed" from="UI/MainMenu/VBoxContainer/LoadRomButton" to="ExamplePlayer" method="_on_load_rom_pressed"]
[connection signal="pressed" from="UI/MainMenu/VBoxContainer/ApplyPatchesButton" to="ExamplePlayer" method="_on_apply_patches_pressed"]
[connection signal="pressed" from="UI/MainMenu/VBoxContainer/StartButton" to="ExamplePlayer" method="_on_start_pressed"]
[connection signal="pressed" from="UI/MainMenu/VBoxContainer/SaveButton" to="ExamplePlayer" method="_on_save_pressed"]
[connection signal="pressed" from="UI/MainMenu/VBoxContainer/LoadSaveButton" to="ExamplePlayer" method="_on_load_save_pressed"]
